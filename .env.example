# QQ Farm Bot 配置文件（本地开发用）
# 复制此文件并重命名为 .env，然后填写真实值
# Docker 用户请使用 docker-compose.yml 中的 environment 字段

# 后端端口
PORT=3000

# 数据加密密钥（生产环境请更换为随机 32 字符）
BOT_ENCRYPT_KEY=qq-farm-bot-default-key-32bytes!

# ========== 邮件通知 SMTP 配置 ==========
# 使用 QQ 邮箱时：授权码在 QQ 邮件设置 -> 账户 -> SMTP 开启处获取
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USER=your-email@qq.com
MAIL_PASS=your-smtp-auth-code
